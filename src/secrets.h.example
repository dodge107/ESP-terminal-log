#pragma once

// Copy this file to secrets.h and fill in your values.
// secrets.h is listed in .gitignore and will never be committed.

// API key — sent by clients in the X-Api-Key header.
// Generate a random value with:  openssl rand -hex 16
// WiFi credentials are NOT stored here — they are configured at runtime
// via the WiFiManager captive portal and saved to NVS on the device.
#define API_KEY    "change-me-to-something-random"
